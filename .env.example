# OpenAI image API configuration.
# Do not commit real API keys.
# Copy this file to `.env` for local use only; `.env` may contain secrets and must not be committed.
# OPENAI_API_KEY is optional if you use the in-app provider configuration or Codex login.
# Environment values are read-only in the app and default to the highest provider priority.
# The top-right "配置" dialog can store one local OpenAI-compatible API config in SQLite;
# saved local keys are masked on readback and never returned in full.
# Do not expose this local app publicly when local provider secrets are configured.
# Leave OPENAI_BASE_URL empty to use the official OpenAI API.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_TIMEOUT_MS=1200000

# Optional Creative Video provider that composes image keyframes into MP4 with FFmpeg.
# Enable this only when the image provider env vars above are configured locally:
# OPENAI_API_KEY, OPENAI_IMAGE_MODEL, and OPENAI_BASE_URL when using a non-default gateway.
VIDEO_PROVIDER_KIND=
# VIDEO_PROVIDER_KIND=keyframe-image

# Keyframe image video defaults.
# Horizontal 4K output is 3840x2160 at 24 FPS.
# Leave KEYFRAME_VIDEO_FRAME_COUNT blank to use duration-based defaults:
# 5 seconds = 6 keyframes, 10 seconds = 12, 20 seconds = 24, 30 seconds = 36.
KEYFRAME_VIDEO_FRAME_COUNT=
KEYFRAME_VIDEO_SECONDS=10
KEYFRAME_VIDEO_WIDTH=3840
KEYFRAME_VIDEO_HEIGHT=2160
KEYFRAME_VIDEO_FPS=24
KEYFRAME_VIDEO_INTERPOLATION=ffmpeg
# FFMPEG_PATH defaults to ffmpeg from PATH. Set an absolute path if needed on Windows.
FFMPEG_PATH=ffmpeg

# Server/runtime.
# Codex OAuth token data, local provider keys, COS secrets, and app state are stored
# in the SQLite database under DATA_DIR. Treat DATA_DIR as sensitive after saving
# any in-app credentials.
PORT=8787
HOST=127.0.0.1
DATA_DIR=./data

# SQLite storage.
# Leave blank to use WAL locally; Docker Compose defaults to DELETE + EXCLUSIVE for bind-mounted data.
SQLITE_JOURNAL_MODE=
SQLITE_LOCKING_MODE=

# Optional cloud asset storage.
# The app stores generated images locally by default. Configure this from the in-app
# cloud storage settings dialog when you want generated images to be uploaded to COS.
# These defaults only prefill the COS settings dialog; SecretId and SecretKey are
# entered in the UI and stored locally in SQLite after a successful test upload.
# Secrets saved from the UI are stored in the local SQLite database and are never
# returned in full by the settings API.
COS_DEFAULT_BUCKET=source-1253253332
COS_DEFAULT_REGION=ap-nanjing
COS_DEFAULT_KEY_PREFIX=gpt-image-canvas/assets
